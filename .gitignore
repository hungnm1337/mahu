## Visual Studio / .NET / WPF common ignores

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/

# Build results
bin/
obj/
out/
artifacts/

# Publish output
publish/
*.Publish.xml

# NuGet
packages/
*.nupkg
packages.lock.json
.nuget/packages/

# MSBuild
*.log
*.vspscc
*.vssscc

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# Resharper
_ReSharper*/
*.DotSettings.user

# JetBrains Rider caches
.idea/
/.idea/

# User secrets (if stored in repo by mistake)
secrets.json

# Temporary files, OS files
Thumbs.db
ehthumbs.db
Desktop.ini
*.DS_Store

# SQL Server files
*.mdf
*.ldf
*.ndf

# Entity Framework
*.dbmdl

# Visual Studio Installer
*.iso

# NuGet symbol packages
*.symbols.nupkg

# VSCode workspace storage
.vscode/

# Rider and others
*.idea

# Dotnet in-source generated files
*.g.cs
*.g.i.cs
*.i.cs

# Logging and other runtime files
*.log

# Keep VS marketplace extension packages out
*.vsix

# Coverage and profiling
*.coverage
*.coveragexml

# Ignore publish profiles generated by Visual Studio
Properties/PublishProfiles/

